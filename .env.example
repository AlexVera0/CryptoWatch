# ============================================================
# CryptoWatch V4 — 环境变量模板
# 复制本文件为 .env 并填入真实密钥
# .env 已被 .gitignore 忽略，绝不能提交到代码仓库
# ============================================================

# ---- Binance API ----
# 请在 Binance 官网 -> API Management 创建，只需要「读取」权限
# 实盘下单需要额外「交易」权限（Dry-Run模式不需要）
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ---- QQ邮箱 SMTP 授权码 ----
# 请在 QQ邮箱 -> 设置 -> 账户 -> 开启SMTP服务 后获取授权码
# 注意：授权码不是QQ密码，是单独生成的16位字符串
SMTP_PASSWORD=your_qq_smtp_authorization_code_here

# ---- 邮件接收地址 ----
# 信号触发时将发送到此邮箱
ALERT_EMAIL_TO=your_receive_email@example.com

# ---- 邮件发送地址（一般与QQ邮箱相同）----
ALERT_EMAIL_FROM=your_qq_email@qq.com

# ---- 可选：覆盖 config.py 中的运行模式 ----
# 取值: research 或 full（CLI参数优先级最高）
# RUN_MODE=research

# ---- 可选：覆盖子集币种数量 ----
# RESEARCH_TOP_N=50

# ---- 可选：覆盖BTC极端行情保护阈值（百分比）----
# BTC_VOLATILE_THRESHOLD=3.0
